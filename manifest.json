<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#0f0f0f">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="DocAuto">
<link rel="manifest" href="manifest.json">
<title>DocAuto</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{--bg:#0f0f0f;--bg2:#1a1a1a;--bg3:#242424;--border:rgba(255,255,255,0.08);--border2:rgba(255,255,255,0.14);--text:#f0f0f0;--text2:#888;--text3:#555;--green:#4ade80;--green-bg:rgba(74,222,128,0.1);--amber:#fb923c;--amber-bg:rgba(251,146,60,0.1);--red:#f87171;--red-bg:rgba(248,113,113,0.1);--accent:#e8e8e8;--accent-text:#000;--radius:14px;--radius-sm:8px;}
body.light{--bg:#f5f5f0;--bg2:#fff;--bg3:#eeede8;--border:rgba(0,0,0,0.08);--border2:rgba(0,0,0,0.14);--text:#111;--text2:#666;--text3:#aaa;--green:#16a34a;--green-bg:rgba(22,163,74,0.1);--amber:#d97706;--amber-bg:rgba(217,119,6,0.1);--red:#dc2626;--red-bg:rgba(220,38,38,0.1);--accent:#111;--accent-text:#fff;}
body.light .topbar{background:rgba(245,245,240,0.95);}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;overflow-x:hidden;}
.topbar{position:sticky;top:0;z-index:50;background:rgba(15,15,15,0.95);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:0.5px solid var(--border);padding:14px 20px 12px;display:flex;align-items:center;justify-content:space-between;}
.topbar-left h1{font-size:20px;font-weight:600;letter-spacing:-0.3px;}
.topbar-left p{font-size:11px;color:var(--text2);margin-top:1px;}
.topbar-actions{display:flex;align-items:center;gap:8px;}
.theme-btn{width:40px;height:40px;border-radius:50%;background:var(--bg3);border:0.5px solid var(--border2);font-size:18px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:transform 0.15s;}
.theme-btn:active{transform:scale(0.92);}
.add-fab{width:40px;height:40px;border-radius:50%;background:var(--accent);color:var(--accent-text);border:none;font-size:22px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:transform 0.15s;}
.add-fab:active{transform:scale(0.92);}
.summary-strip{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;padding:14px 16px 10px;}
.summary-pill{background:var(--bg2);border:0.5px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;display:flex;flex-direction:column;gap:2px;}
.summary-pill .num{font-size:22px;font-weight:600;line-height:1;}
.summary-pill .lbl{font-size:10px;color:var(--text2);}
.num-ok{color:var(--green)}.num-warn{color:var(--amber)}.num-danger{color:var(--red)}
.cars-list{padding:4px 16px 100px;display:flex;flex-direction:column;gap:10px;}
.car-card{background:var(--bg2);border:0.5px solid var(--border);border-radius:var(--radius);overflow:hidden;}
.car-card-header{display:flex;align-items:center;gap:12px;padding:14px 16px;cursor:pointer;transition:background 0.1s;}
.car-card-header:hover{background:var(--bg3);}

/* Car photo thumb */
.car-thumb{width:52px;height:52px;border-radius:10px;background:var(--bg3);border:0.5px solid var(--border);display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden;}
.car-thumb img{width:100%;height:100%;object-fit:cover;}
.car-thumb-placeholder{font-size:26px;line-height:1;}

.car-meta{flex:1;min-width:0;}
.car-name{font-size:15px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.car-plate{font-size:11px;font-family:'DM Mono',monospace;color:var(--text2);margin-top:3px;background:var(--bg3);border-radius:4px;padding:1px 6px;display:inline-block;}
.car-right{display:flex;align-items:center;gap:10px;flex-shrink:0;}
.status-dot{width:9px;height:9px;border-radius:50%;}
.dot-ok{background:var(--green);box-shadow:0 0 6px var(--green);}
.dot-warn{background:var(--amber);box-shadow:0 0 6px var(--amber);}
.dot-danger{background:var(--red);box-shadow:0 0 6px var(--red);}
.chevron{color:var(--text3);font-size:12px;transition:transform 0.2s;}
.chevron.open{transform:rotate(180deg);}

.car-docs{border-top:0.5px solid var(--border);}
.doc-row{display:flex;align-items:center;padding:12px 16px;border-bottom:0.5px solid var(--border);gap:12px;cursor:pointer;transition:background 0.1s;}
.doc-row:last-child{border-bottom:none;}
.doc-row:hover{background:var(--bg3);}
.doc-badge{font-size:10px;font-weight:600;letter-spacing:0.05em;padding:3px 8px;border-radius:5px;flex-shrink:0;min-width:72px;text-align:center;}
.badge-ok{background:var(--green-bg);color:var(--green);}
.badge-warn{background:var(--amber-bg);color:var(--amber);}
.badge-danger{background:var(--red-bg);color:var(--red);}
.doc-name{font-size:14px;font-weight:500;flex:1;}
.doc-expiry{font-size:11px;color:var(--text2);flex-shrink:0;}
.doc-days{font-size:11px;flex-shrink:0;min-width:60px;text-align:right;}
.days-ok{color:var(--green)}.days-warn{color:var(--amber)}.days-danger{color:var(--red)}
.car-footer{border-top:0.5px solid var(--border);display:flex;}
.car-footer button{flex:1;padding:12px;background:none;border:none;font-size:13px;font-family:'DM Sans',sans-serif;cursor:pointer;transition:background 0.1s;color:var(--text2);}
.car-footer button:hover{background:var(--bg3);}
.car-footer .btn-del{color:var(--red);border-left:0.5px solid var(--border);}
.empty{display:flex;flex-direction:column;align-items:center;padding:60px 32px;text-align:center;gap:12px;}
.empty-icon{font-size:56px;}
.empty h2{font-size:18px;font-weight:600;}
.empty p{font-size:14px;color:var(--text2);line-height:1.5;}

/* Sheet */
.sheet-overlay{position:fixed;inset:0;z-index:200;background:rgba(0,0,0,0.7);display:flex;align-items:flex-end;animation:fadeIn 0.18s ease;}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.sheet{width:100%;background:var(--bg2);border-radius:20px 20px 0 0;border-top:0.5px solid var(--border2);padding-bottom:28px;animation:slideUp 0.25s cubic-bezier(0.32,0.72,0,1);max-height:92vh;overflow-y:auto;}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.sheet-handle{width:36px;height:4px;background:var(--border2);border-radius:2px;margin:12px auto 4px;}
.sheet-header{padding:8px 20px 16px;display:flex;align-items:center;justify-content:space-between;}
.sheet-title{font-size:17px;font-weight:600;}
.sheet-close{background:var(--bg3);border:none;color:var(--text2);width:30px;height:30px;border-radius:50%;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.sheet-body{padding:0 20px 8px;display:flex;flex-direction:column;gap:18px;}
.field{display:flex;flex-direction:column;gap:6px;}
.field label{font-size:12px;font-weight:500;color:var(--text2);letter-spacing:0.04em;}
.field input[type=text],.field input[type=number],.field input[type=date]{background:var(--bg3);border:0.5px solid var(--border2);border-radius:var(--radius-sm);padding:12px 14px;color:var(--text);font-size:15px;font-family:'DM Sans',sans-serif;width:100%;}
.field input:focus{outline:none;border-color:rgba(255,255,255,0.35);}
body.light .field input:focus{border-color:rgba(0,0,0,0.4);}
.field input[type=date]{color-scheme:dark;}
body.light .field input[type=date]{color-scheme:light;}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.sheet-section-title{font-size:12px;color:var(--text3);text-transform:uppercase;letter-spacing:0.08em;padding-top:4px;border-top:0.5px solid var(--border);}
.btn-primary{margin:16px 20px 0;background:var(--accent);color:var(--accent-text);border:none;border-radius:var(--radius-sm);padding:15px;font-size:15px;font-weight:600;font-family:'DM Sans',sans-serif;width:calc(100% - 40px);cursor:pointer;transition:opacity 0.15s;}
.btn-primary:hover{opacity:0.85;}
.rev-preview{font-size:13px;color:var(--text2);padding:4px 0 0;line-height:1.6;}

/* Photo upload */
.photo-upload-area{display:flex;flex-direction:column;align-items:center;gap:10px;}
.photo-preview-box{width:100%;height:160px;border-radius:var(--radius-sm);background:var(--bg3);border:1.5px dashed var(--border2);display:flex;align-items:center;justify-content:center;overflow:hidden;cursor:pointer;position:relative;transition:border-color 0.15s;}
.photo-preview-box:hover{border-color:var(--text2);}
.photo-preview-box img{width:100%;height:100%;object-fit:cover;border-radius:var(--radius-sm);}
.photo-placeholder{display:flex;flex-direction:column;align-items:center;gap:8px;color:var(--text2);}
.photo-placeholder .ph-icon{font-size:32px;}
.photo-placeholder span{font-size:13px;}
.photo-actions{display:flex;gap:8px;width:100%;}
.photo-btn{flex:1;padding:10px;background:var(--bg3);border:0.5px solid var(--border2);border-radius:var(--radius-sm);font-size:13px;font-family:'DM Sans',sans-serif;color:var(--text2);cursor:pointer;text-align:center;transition:background 0.1s;}
.photo-btn:hover{background:var(--bg);color:var(--text);}
.photo-btn.danger{color:var(--red);border-color:rgba(248,113,113,0.3);}
</style>
</head>
<body>

<div class="topbar">
  <div class="topbar-left"><h1>DocAuto</h1><p>ITP · RCA · Rovinieta · Revizie</p></div>
  <div class="topbar-actions">
    <button class="theme-btn" id="themeBtn" onclick="toggleTheme()">&#127769;</button>
    <button class="add-fab" onclick="openAddCar()">+</button>
  </div>
</div>
<div class="summary-strip" id="summaryStrip"></div>
<div class="cars-list" id="carsList"></div>
<div id="sheetOverlay" style="display:none;"></div>
<input type="file" id="photoInput" accept="image/*" style="display:none" onchange="handlePhotoFile(this)">

<script>
var STORAGE_KEY = 'docauto_v5';
var DOC_KEYS = ['itp','rca','rovinieta','revizie'];
var DOC_LABELS = {itp:'ITP',rca:'RCA',rovinieta:'Rovinieta',revizie:'Revizie'};
var cars = [], expanded = {};
var _editingCarId = null; // which car is being edited in the sheet

function load(){
  try{ cars = JSON.parse(localStorage.getItem(STORAGE_KEY))||[]; } catch(e){ cars=[]; }
  if(!cars.length){
    cars=[
      {id:1,name:'BMW E36',plate:'B 733 ETY',photo:'',docs:{itp:{expiry:'2025-08-15'},rca:{expiry:'2025-07-01'},rovinieta:{expiry:'2025-05-10'},revizie:{lastKm:'110000',currentKm:'115000',interval:'10000'}}},
      {id:2,name:'Dacia Logan',plate:'IF 01 XYZ',photo:'',docs:{itp:{expiry:'2026-11-20'},rca:{expiry:'2026-06-15'},rovinieta:{expiry:'2026-12-01'},revizie:{lastKm:'85000',currentKm:'89500',interval:'10000'}}}
    ];
  }
}
function save(){ try{ localStorage.setItem(STORAGE_KEY,JSON.stringify(cars)); } catch(e){} }

/* ── HELPERS ── */
function daysLeft(d){
  if(!d) return null;
  var dt=new Date(d); dt.setHours(0,0,0,0);
  var n=new Date(); n.setHours(0,0,0,0);
  return Math.ceil((dt-n)/86400000);
}
function statusOf(d){ if(d===null||d<0) return'danger'; if(d<=30) return'warn'; return'ok'; }
function revKmLeft(rev){
  if(!rev||!rev.lastKm) return null;
  return (parseInt(rev.lastKm)||0)+(parseInt(rev.interval)||10000)-(parseInt(rev.currentKm)||0);
}
function revStatus(rev){
  var km=revKmLeft(rev);
  if(km===null) return'danger'; if(km<=0) return'danger'; if(km<=1500) return'warn'; return'ok';
}
function revNextKm(rev){
  if(!rev||!rev.lastKm) return null;
  return (parseInt(rev.lastKm)||0)+(parseInt(rev.interval)||10000);
}
function carStatus(c){
  var w='ok';
  for(var i=0;i<DOC_KEYS.length;i++){
    var k=DOC_KEYS[i], s;
    if(k==='revizie') s=revStatus(c.docs&&c.docs.revizie);
    else s=statusOf(daysLeft(c.docs&&c.docs[k]&&c.docs[k].expiry));
    if(s==='danger') return'danger';
    if(s==='warn') w='warn';
  }
  return w;
}
function fmtDate(d){ if(!d) return '\u2014'; return new Date(d).toLocaleDateString('ro-RO',{day:'2-digit',month:'short',year:'numeric'}); }
function fmtKm(n){ if(n===null||n===undefined||n==='') return'\u2014'; return Number(n).toLocaleString('ro-RO')+' km'; }
function daysLabel(d){ if(d===null) return'Necompletat'; if(d<0) return'Exp. '+Math.abs(d)+'z'; if(d===0) return'Azi!'; if(d===1) return'Maine!'; return d+'z'; }
function badgeLabel(d){ if(d===null) return'LIPSA'; if(d<0) return'EXPIRAT'; if(d<=30) return'EXPIRA'; return'VALID'; }

/* ── PHOTO ── */
function thumbHtml(photo, name){
  if(photo){
    return '<div class="car-thumb"><img src="'+photo+'" alt="'+name+'"></div>';
  }
  // Initials fallback
  var initials = (name||'?').split(' ').map(function(w){return w[0];}).join('').slice(0,2).toUpperCase();
  return '<div class="car-thumb"><div class="car-thumb-placeholder">'+initials+'</div></div>';
}

function resizeImage(file, cb){
  var reader = new FileReader();
  reader.onload = function(e){
    var img = new Image();
    img.onload = function(){
      var maxW=600, maxH=400;
      var w=img.width, h=img.height;
      if(w>maxW){ h=Math.round(h*maxW/w); w=maxW; }
      if(h>maxH){ w=Math.round(w*maxH/h); h=maxH; }
      var canvas=document.createElement('canvas');
      canvas.width=w; canvas.height=h;
      canvas.getContext('2d').drawImage(img,0,0,w,h);
      cb(canvas.toDataURL('image/jpeg',0.82));
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

var _photoTarget = null; // 'add' or carId for edit

function triggerPhotoUpload(target){
  _photoTarget = target;
  var inp = document.getElementById('photoInput');
  inp.value='';
  inp.click();
}

function handlePhotoFile(input){
  if(!input.files||!input.files[0]) return;
  resizeImage(input.files[0], function(dataUrl){
    if(_photoTarget === 'add'){
      // update preview in add sheet
      var prev = document.getElementById('photo_preview_img');
      if(prev){ prev.src=dataUrl; prev.style.display='block'; }
      var ph = document.getElementById('photo_placeholder');
      if(ph) ph.style.display='none';
      var hidden = document.getElementById('f_photo');
      if(hidden) hidden.value=dataUrl;
    } else {
      // edit - find car and save
      var car = cars.find(function(c){return c.id===_photoTarget;});
      if(car){ car.photo=dataUrl; save(); closeSheet(); render(); }
    }
  });
}

function removePhoto(target){
  if(target==='add'){
    var prev=document.getElementById('photo_preview_img');
    if(prev){prev.src='';prev.style.display='none';}
    var ph=document.getElementById('photo_placeholder');
    if(ph) ph.style.display='flex';
    var hidden=document.getElementById('f_photo');
    if(hidden) hidden.value='';
  } else {
    var car=cars.find(function(c){return c.id===target;});
    if(car){ car.photo=''; save(); closeSheet(); render(); }
  }
}

/* ── RENDER ── */
function renderSummary(){
  var ok=0,w=0,d=0;
  cars.forEach(function(c){ var s=carStatus(c); if(s==='ok')ok++; else if(s==='warn')w++; else d++; });
  document.getElementById('summaryStrip').innerHTML=
    '<div class="summary-pill"><span class="num num-ok">'+ok+'</span><span class="lbl">Fara probleme</span></div>'+
    '<div class="summary-pill"><span class="num num-warn">'+w+'</span><span class="lbl">Expira curand</span></div>'+
    '<div class="summary-pill"><span class="num num-danger">'+d+'</span><span class="lbl">Probleme</span></div>';
}

function renderCars(){
  var list=document.getElementById('carsList');
  if(!cars.length){
    list.innerHTML='<div class="empty"><div class="empty-icon">&#128663;</div><h2>Nicio masina</h2><p>Apasa + pentru a adauga prima masina.</p></div>';
    return;
  }
  list.innerHTML=cars.map(function(car){
    var cs=carStatus(car), isOpen=!!expanded[car.id];
    var docsHtml=DOC_KEYS.map(function(k){
      if(k==='revizie'){
        var rev=car.docs&&car.docs.revizie||{};
        var st=revStatus(rev), kmLeft=revKmLeft(rev), nxt=revNextKm(rev);
        var badge=rev.lastKm?(kmLeft<=0?'DEPASIT':kmLeft<=1500?'CURAND':'OK'):'LIPSA';
        var info=rev.lastKm?'urm. la '+fmtKm(nxt):'Necompletat';
        var kmStr=kmLeft===null?'':(kmLeft<=0?Math.abs(kmLeft)+' km dep.':kmLeft.toLocaleString('ro-RO')+' km');
        return '<div class="doc-row" onclick="openEditDoc('+car.id+',\'revizie\')">'+
          '<span class="doc-badge badge-'+st+'">'+badge+'</span>'+
          '<span class="doc-name">Revizie</span>'+
          '<span class="doc-expiry">'+info+'</span>'+
          '<span class="doc-days days-'+st+'">'+kmStr+'</span></div>';
      }
      var days=daysLeft(car.docs&&car.docs[k]&&car.docs[k].expiry), st=statusOf(days);
      return '<div class="doc-row" onclick="openEditDoc('+car.id+',\''+k+'\')">'+
        '<span class="doc-badge badge-'+st+'">'+badgeLabel(days)+'</span>'+
        '<span class="doc-name">'+DOC_LABELS[k]+'</span>'+
        '<span class="doc-expiry">'+fmtDate(car.docs&&car.docs[k]&&car.docs[k].expiry)+'</span>'+
        '<span class="doc-days days-'+st+'">'+daysLabel(days)+'</span></div>';
    }).join('');
    return '<div class="car-card">'+
      '<div class="car-card-header" onclick="toggle('+car.id+')">'+
        thumbHtml(car.photo, car.name)+
        '<div class="car-meta"><div class="car-name">'+car.name+'</div><div class="car-plate">'+(car.plate||'fara numar')+'</div></div>'+
        '<div class="car-right"><div class="status-dot dot-'+cs+'"></div><span class="chevron'+(isOpen?' open':'')+'">&#9660;</span></div>'+
      '</div>'+
      (isOpen?'<div class="car-docs">'+docsHtml+'</div><div class="car-footer"><button onclick="openEditCar('+car.id+')">&#9998; Editeaza</button><button class="btn-del" onclick="deleteCar('+car.id+')">Sterge</button></div>':'')+
    '</div>';
  }).join('');
}

function render(){ renderSummary(); renderCars(); }
function toggle(id){ expanded[id]=!expanded[id]; render(); }
function deleteCar(id){ if(!confirm('Stergi aceasta masina?')) return; cars=cars.filter(function(c){return c.id!==id;}); delete expanded[id]; save(); render(); }

/* ── SHEET ── */
function openSheet(html){
  var ov=document.getElementById('sheetOverlay');
  ov.style.display='flex'; ov.className='sheet-overlay';
  ov.innerHTML='<div class="sheet"><div class="sheet-handle"></div>'+html+'</div>';
  ov.onclick=function(e){if(e.target===ov)closeSheet();};
}
function closeSheet(){ var ov=document.getElementById('sheetOverlay'); ov.style.display='none'; ov.innerHTML=''; }

function photoUploadAreaHtml(currentPhoto, target){
  var hasPhoto = currentPhoto && currentPhoto.length > 0;
  var previewHtml = hasPhoto
    ? '<img id="photo_preview_img" src="'+currentPhoto+'" style="width:100%;height:100%;object-fit:cover;">'
    : '<img id="photo_preview_img" src="" style="display:none;width:100%;height:100%;object-fit:cover;">';
  var placeholderStyle = hasPhoto ? 'display:none;' : '';
  return '<div class="photo-upload-area">'+
    '<div class="photo-preview-box" onclick="triggerPhotoUpload(\''+target+'\')">'+
      previewHtml+
      '<div class="photo-placeholder" id="photo_placeholder" style="'+placeholderStyle+'">'+
        '<div class="ph-icon">&#128247;</div>'+
        '<span>Apasa sa adaugi o poza</span>'+
      '</div>'+
    '</div>'+
    '<div class="photo-actions">'+
      '<button class="photo-btn" onclick="triggerPhotoUpload(\''+target+'\')">&#128247; Alege poza</button>'+
      (hasPhoto?'<button class="photo-btn danger" onclick="removePhoto(\''+target+'\')">Sterge poza</button>':'')+
    '</div>'+
  '</div>';
}

/* ── ADD CAR ── */
function openAddCar(){
  openSheet(
    '<div class="sheet-header"><span class="sheet-title">Masina noua</span><button class="sheet-close" onclick="closeSheet()">\u2715</button></div>'+
    '<div class="sheet-body">'+
      '<div class="field-row">'+
        '<div class="field"><label>MARCA / MODEL</label><input type="text" id="f_name" placeholder="ex: BMW E36"></div>'+
        '<div class="field"><label>NUMAR INMATR.</label><input type="text" id="f_plate" placeholder="ex: B 01 ABC"></div>'+
      '</div>'+
      '<div class="field"><label>POZA MASINA</label>'+photoUploadAreaHtml('','add')+'</div>'+
      '<input type="hidden" id="f_photo" value="">'+
      '<div class="sheet-section-title">Documente (optional)</div>'+
      '<div class="field-row"><div class="field"><label>ITP</label><input type="date" id="f_itp"></div><div class="field"><label>RCA</label><input type="date" id="f_rca"></div></div>'+
      '<div class="field"><label>ROVINIETA</label><input type="date" id="f_rovinieta"></div>'+
      '<div class="sheet-section-title">Revizie (km)</div>'+
      '<div class="field-row"><div class="field"><label>ULTIMA REVIZIE LA</label><input type="number" id="f_rev_last" placeholder="ex: 110000"></div><div class="field"><label>KM ACTUALI</label><input type="number" id="f_rev_cur" placeholder="ex: 115000"></div></div>'+
      '<div class="field"><label>INTERVAL (KM)</label><input type="number" id="f_rev_int" value="10000"></div>'+
      '<div class="rev-preview" id="add_rev_preview"></div>'+
    '</div>'+
    '<button class="btn-primary" onclick="saveCar()">Salveaza masina</button>'
  );
  ['f_rev_last','f_rev_cur','f_rev_int'].forEach(function(id){
    var el=document.getElementById(id);
    if(el) el.addEventListener('input',calcAddPreview);
  });
}

function calcAddPreview(){
  var last=parseInt(document.getElementById('f_rev_last').value)||0;
  var cur=parseInt(document.getElementById('f_rev_cur').value)||0;
  var iv=parseInt(document.getElementById('f_rev_int').value)||10000;
  var p=document.getElementById('add_rev_preview');
  if(!p||!last){if(p)p.innerHTML='';return;}
  var next=last+iv,left=next-cur;
  p.innerHTML='Urmatoarea revizie la <b>'+next.toLocaleString('ro-RO')+' km</b><br>'+
    (left>0?'Mai sunt: <b>'+left.toLocaleString('ro-RO')+' km</b>':'<span style="color:var(--red)">Depasita cu <b>'+Math.abs(left).toLocaleString('ro-RO')+' km</b></span>');
}

function saveCar(){
  var name=(document.getElementById('f_name').value||'').trim();
  if(!name){ alert('Introdu marca/modelul'); return; }
  var car={
    id:Date.now(), name:name,
    plate:(document.getElementById('f_plate').value||'').trim(),
    photo:document.getElementById('f_photo').value||'',
    docs:{
      itp:{expiry:document.getElementById('f_itp').value||''},
      rca:{expiry:document.getElementById('f_rca').value||''},
      rovinieta:{expiry:document.getElementById('f_rovinieta').value||''},
      revizie:{lastKm:document.getElementById('f_rev_last').value||'',currentKm:document.getElementById('f_rev_cur').value||'',interval:document.getElementById('f_rev_int').value||'10000'}
    }
  };
  cars.push(car); expanded[car.id]=true; save(); closeSheet(); render();
}

/* ── EDIT CAR ── */
function openEditCar(id){
  var car=cars.find(function(c){return c.id===id;}); if(!car) return;
  openSheet(
    '<div class="sheet-header"><span class="sheet-title">Editeaza masina</span><button class="sheet-close" onclick="closeSheet()">\u2715</button></div>'+
    '<div class="sheet-body">'+
      '<div class="field-row">'+
        '<div class="field"><label>MARCA / MODEL</label><input type="text" id="fe_name" value="'+car.name+'"></div>'+
        '<div class="field"><label>NUMAR INMATR.</label><input type="text" id="fe_plate" value="'+(car.plate||'')+'"></div>'+
      '</div>'+
      '<div class="field"><label>POZA MASINA</label>'+photoUploadAreaHtml(car.photo||'',id)+'</div>'+
    '</div>'+
    '<button class="btn-primary" onclick="saveEditCar('+id+')">Salveaza</button>'
  );
}

function saveEditCar(id){
  var car=cars.find(function(c){return c.id===id;}); if(!car) return;
  car.name=(document.getElementById('fe_name').value||'').trim()||car.name;
  car.plate=(document.getElementById('fe_plate').value||'').trim();
  save(); closeSheet(); render();
}

/* ── EDIT DOC ── */
function openEditDoc(carId,key){
  var car=cars.find(function(c){return c.id===carId;}); if(!car) return;
  if(key==='revizie'){
    var rev=car.docs&&car.docs.revizie||{};
    openSheet(
      '<div class="sheet-header"><span class="sheet-title">Revizie \u2014 '+car.name+'</span><button class="sheet-close" onclick="closeSheet()">\u2715</button></div>'+
      '<div class="sheet-body">'+
        '<div class="field-row"><div class="field"><label>ULTIMA REVIZIE LA</label><input type="number" id="fd_rev_last" value="'+(rev.lastKm||'')+'" placeholder="ex: 110000"></div><div class="field"><label>KM ACTUALI</label><input type="number" id="fd_rev_cur" value="'+(rev.currentKm||'')+'" placeholder="ex: 115000"></div></div>'+
        '<div class="field"><label>INTERVAL (KM)</label><input type="number" id="fd_rev_int" value="'+(rev.interval||'10000')+'"></div>'+
        '<div class="rev-preview" id="edit_rev_preview"></div>'+
      '</div>'+
      '<button class="btn-primary" onclick="saveRevDoc('+carId+')">Salveaza</button>'
    );
    ['fd_rev_last','fd_rev_cur','fd_rev_int'].forEach(function(id){
      var el=document.getElementById(id);
      if(el) el.addEventListener('input',calcEditPreview);
    });
    calcEditPreview();
    return;
  }
  openSheet(
    '<div class="sheet-header"><span class="sheet-title">'+DOC_LABELS[key]+' \u2014 '+car.name+'</span><button class="sheet-close" onclick="closeSheet()">\u2715</button></div>'+
    '<div class="sheet-body"><div class="field"><label>DATA EXPIRARE '+DOC_LABELS[key]+'</label><input type="date" id="fd_expiry" value="'+((car.docs&&car.docs[key]&&car.docs[key].expiry)||'')+'"></div></div>'+
    '<button class="btn-primary" onclick="saveDoc('+carId+',\''+key+'\')">Salveaza</button>'
  );
}

function calcEditPreview(){
  var last=parseInt(document.getElementById('fd_rev_last').value)||0;
  var cur=parseInt(document.getElementById('fd_rev_cur').value)||0;
  var iv=parseInt(document.getElementById('fd_rev_int').value)||10000;
  var p=document.getElementById('edit_rev_preview');
  if(!p||!last){if(p)p.innerHTML='';return;}
  var next=last+iv,left=next-cur;
  p.innerHTML='Urmatoarea revizie la <b>'+next.toLocaleString('ro-RO')+' km</b><br>'+
    (left>0?'Mai sunt: <b>'+left.toLocaleString('ro-RO')+' km</b>':'<span style="color:var(--red)">Depasita cu <b>'+Math.abs(left).toLocaleString('ro-RO')+' km</b></span>');
}

function saveRevDoc(carId){
  var car=cars.find(function(c){return c.id===carId;}); if(!car) return;
  if(!car.docs) car.docs={};
  car.docs.revizie={lastKm:document.getElementById('fd_rev_last').value||'',currentKm:document.getElementById('fd_rev_cur').value||'',interval:document.getElementById('fd_rev_int').value||'10000'};
  save(); closeSheet(); render();
}

function saveDoc(carId,key){
  var car=cars.find(function(c){return c.id===carId;}); if(!car) return;
  if(!car.docs) car.docs={}; if(!car.docs[key]) car.docs[key]={};
  car.docs[key].expiry=document.getElementById('fd_expiry').value;
  save(); closeSheet(); render();
}

/* ── THEME ── */
function toggleTheme(){
  var isLight=document.body.classList.toggle('light');
  document.getElementById('themeBtn').innerHTML=isLight?'&#9679;':'&#127769;';
  try{ localStorage.setItem('docauto_theme',isLight?'light':'dark'); } catch(e){}
}
(function(){
  try{
    if(localStorage.getItem('docauto_theme')==='light'){
      document.body.classList.add('light');
      document.getElementById('themeBtn').innerHTML='&#9679;';
    }
  } catch(e){}
})();

/* ── SERVICE WORKER ── */
if('serviceWorker' in navigator){
  window.addEventListener('load',function(){
    navigator.serviceWorker.register('sw.js').catch(function(){});
  });
}

load(); render();
</script>
</body>
</html>